# TTCS local development example. Copy to .env for local use.

# Backend
DATABASE_URL=mysql+pymysql://ttcs:ttcs_local_password@127.0.0.1:3306/ttcs
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET_KEY=replace-with-a-local-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Demo seed, local/dev only
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=DemoPass123!
DEMO_USER_DISPLAY_NAME=TTCS Demo User
